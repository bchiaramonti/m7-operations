# m7-ritual-gestao — variaveis de ambiente sensiveis
# COPIE este arquivo para `.env` (mesmo diretorio) ou para
# `~/.claude/credentials/.env` (convencao M7) e preencha os valores.
#
# NUNCA comite o arquivo .env real. Ele esta no .gitignore.

# Token do bot Slack "m7-desempenho" (formato: xoxb-...).
# Obtido em api.slack.com/apps -> M7 Rituais -> OAuth & Permissions.
# Scopes minimos requeridos: chat:write, files:write, users:read, im:write.
SLACK_BOT_TOKEN=xoxb-REPLACE-ME
