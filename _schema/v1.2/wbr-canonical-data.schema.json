{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://m7.com.br/schemas/wbr-canonical-data-v1.2.json",
  "title": "WBR Canonical Data v1.2",
  "description": "Schema do canonical WBR JSON emitido por E6 (consolidating-wbr Fase 4.5). Single Source of Truth para todos os artefatos do WBR (Estruturado MD, Narrativo MD, HTML, PDF). Schema v1.2 (S2a 2026-05-18): adicionado causa_raiz_resumo, n2.{esp}.volume_estagnado, vol_em_risco, aggregation_rule_applied, acoes.* (4 categorias).",
  "type": "object",
  "required": ["_schema", "vertical", "data_referencia", "indicadores"],
  "properties": {
    "_schema": {
      "type": "string",
      "pattern": "^wbr-canonical-data v1\\.[0-2]$",
      "description": "Versao do schema. v1.0 (legacy), v1.1 (2026-05-12: direction + por_canal + M+1), v1.2 (2026-05-18: causa_raiz_resumo + volume_estagnado + vol_em_risco + aggregation_rule + acoes)"
    },
    "_generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "vertical": {
      "type": "string",
      "description": "Nome da vertical (consorcios, seguros, pj2, etc.)"
    },
    "data_referencia": {
      "type": "string",
      "format": "date",
      "description": "Data do snapshot YYYY-MM-DD"
    },
    "checkpoint_label": {
      "type": "string"
    },
    "meta": {
      "type": "object",
      "properties": {
        "is_first_ritual_of_month": {"type": "boolean"},
        "vertical": {"type": "string"},
        "ciclo_label": {"type": "string"},
        "snapshot_at": {"type": "string", "format": "date-time"}
      }
    },
    "semaforo_resumo": {
      "type": "object",
      "properties": {
        "verde": {"type": "integer", "minimum": 0},
        "amarelo": {"type": "integer", "minimum": 0},
        "vermelho": {"type": "integer", "minimum": 0},
        "cinza_sem_meta": {"type": "integer", "minimum": 0},
        "total_com_meta": {"type": "integer", "minimum": 0},
        "total_indicadores": {"type": "integer", "minimum": 0}
      }
    },
    "indicadores": {
      "type": "object",
      "description": "Dict de indicadores por id. Cada valor segue indicator_entry schema.",
      "additionalProperties": {
        "$ref": "#/$defs/indicator_entry"
      }
    },
    "projecoes": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/projection_entry"
      }
    },
    "acoes": {
      "$ref": "#/$defs/acoes_block",
      "description": "Bloco emitido em v1.2 (S2a B4.18) vindo do sidecar e4-acoes-{vertical}.json"
    },
    "diagnostico_principal": {
      "type": "object",
      "properties": {
        "manchete": {"type": "string"},
        "gap_principal": {"type": "string"}
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "indicator_entry": {
      "type": "object",
      "properties": {
        "tipo": {"type": "string", "examples": ["KPI", "PPI"]},
        "label": {"type": "string"},
        "unit": {"type": "string", "examples": ["BRL", "pct", "count", "ratio", "days"]},
        "meta": {"type": ["number", "null"]},
        "meta_label": {"type": ["string", "null"]},
        "realizado": {"type": ["number", "null"]},
        "realizado_label": {"type": ["string", "null"]},
        "gap_abs": {"type": ["number", "null"]},
        "gap_label": {"type": ["string", "null"]},
        "pct_atingimento": {"type": ["number", "null"]},
        "pct_label": {"type": ["string", "null"]},
        "status": {
          "type": "string",
          "enum": ["verde", "amarelo", "vermelho", "cinza"]
        },
        "status_emoji": {"type": "string"},
        "direction": {
          "type": "string",
          "enum": ["maior_melhor", "menor_melhor"]
        },
        "regra_semaforo": {
          "type": "string",
          "enum": [
            "kpi_padrao_95_80",
            "metas_ppi_a_maior_melhor",
            "metas_ppi_a_menor_melhor",
            "metas_ppi_zero_target",
            "metas_ppi_pendente",
            "sem_meta_formal"
          ]
        },
        "causa_raiz_resumo": {
          "type": ["string", "null"],
          "maxLength": 300,
          "description": "1-2 frases sintetizando causa-raiz. NOVO v1.2 (S2a B4.17). Vem de sidecar e3-causa-raiz-{vertical}.json (Fase 4.5.d)."
        },
        "n2": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "realizado": {"type": ["number", "null"]},
              "meta": {"type": ["number", "null"]},
              "pct": {"type": ["number", "null"]},
              "status": {"type": "string", "enum": ["verde", "amarelo", "vermelho", "cinza", "mute"]},
              "volume_estagnado": {
                "type": ["number", "null"],
                "description": "NOVO v1.2 — apenas para indicador oportunidades_estagnadas_funil*. Soma de volume das rows N2-Especialista (substitui fallback build_deck _vol_estagnado_for_esp)."
              },
              "causa_raiz_resumo": {
                "type": ["string", "null"],
                "maxLength": 300,
                "description": "OPCIONAL — frase especifica para especialista quando E3 detectou concentracao individual."
              }
            }
          }
        },
        "vol_em_risco": {
          "type": ["number", "null"],
          "description": "NOVO v1.2 — apenas para oportunidades_estagnadas_funil*. SUM(n2.*.volume_estagnado). Consumido por build_deck Matriz N3 célula Total."
        },
        "por_canal": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "qty": {"type": ["number", "integer", "null"]},
              "vol": {"type": ["number", "null"]},
              "qty_won": {"type": ["number", "integer", "null"]},
              "pct_ativas": {"type": ["number", "null"]}
            }
          }
        },
        "aggregation_rule_applied": {
          "type": "boolean",
          "description": "NOVO v1.2 — true quando N1/N2 foi derivado via aggregation_rule do YAML (Fase 4.5.f). Indicadores classicos: omit ou false."
        },
        "rows": {
          "type": "array",
          "description": "Opcional — rows do indicador (output_contract). Util para inspecao mas E6 ja consolida em n1/n2."
        },
        "riscos_principais": {
          "type": "array",
          "items": {"$ref": "#/$defs/narrative_item_rico"}
        },
        "destaques_positivos": {
          "type": "array",
          "items": {"$ref": "#/$defs/narrative_item_rico"}
        },
        "anomalias": {
          "type": "array",
          "items": {"$ref": "#/$defs/anomalia_item"}
        }
      }
    },
    "projection_entry": {
      "type": "object",
      "properties": {
        "M0": {"$ref": "#/$defs/projection_horizon"},
        "M+1": {"$ref": "#/$defs/projection_horizon"}
      }
    },
    "projection_horizon": {
      "type": "object",
      "properties": {
        "meta_mes": {"type": ["number", "null"]},
        "base": {"type": ["number", "null"]},
        "pessimista": {"type": ["number", "null"]},
        "otimista": {"type": ["number", "null"]},
        "classificacao": {"type": "string"}
      }
    },
    "acoes_block": {
      "type": "object",
      "properties": {
        "criticas": {"type": "array", "items": {"$ref": "#/$defs/task_item"}},
        "atrasadas": {"type": "array", "items": {"$ref": "#/$defs/task_item"}},
        "em_dia_priorizadas": {"type": "array", "items": {"$ref": "#/$defs/task_item"}},
        "concluidas_eficazes": {"type": "array", "items": {"$ref": "#/$defs/task_item"}},
        "metricas_agregadas": {"type": "object"}
      }
    },
    "task_item": {
      "type": "object",
      "required": ["id", "name", "status"],
      "properties": {
        "id": {"type": "string"},
        "name": {"type": "string"},
        "status": {"type": "string"},
        "priority": {"type": ["string", "null"]},
        "due_date": {"type": ["string", "null"]},
        "date_created": {"type": ["string", "null"]},
        "date_updated": {"type": ["string", "null"]},
        "date_closed": {
          "type": ["string", "null"],
          "description": "NOVO v6.4.2 do collecting-data (S2a B4.15)"
        },
        "responsavel_externo": {"type": ["string", "null"]},
        "indicador_impactado": {"type": ["string", "null"]},
        "origem": {"type": ["string", "null"]},
        "receita_impacto": {"type": ["number", "null"]},
        "volume_impacto": {"type": ["number", "null"]},
        "criada_em_ritual_anterior": {"type": "boolean"},
        "aging_dias": {"type": ["integer", "null"]},
        "dias_restantes": {"type": ["integer", "null"]},
        "eficacia": {
          "type": ["string", "null"],
          "enum": ["eficaz", "parcial", "sem_efeito", "dados_insuficientes", null]
        },
        "url": {"type": "string"},
        "is_evidencia_e3": {
          "type": "boolean",
          "description": "Flag cross-link com sidecar E3 — task referencia indicador vermelho"
        }
      }
    },
    "narrative_item_rico": {
      "type": "object",
      "required": ["titulo", "texto"],
      "properties": {
        "titulo": {"type": "string"},
        "texto": {"type": "string"},
        "causa": {"type": "string"},
        "impacto": {"type": "string"},
        "owner": {"type": "string"},
        "prazo": {"type": "string", "format": "date"}
      },
      "description": "Schema rich-narrative MANDATORIO desde 2026-05-14 (Fase 4.5.c). NUNCA list[str] de frases soltas."
    },
    "anomalia_item": {
      "type": "object",
      "required": ["descricao"],
      "properties": {
        "descricao": {"type": "string"},
        "acao": {"type": "string"}
      }
    }
  }
}
